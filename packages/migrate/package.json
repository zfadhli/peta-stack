{
  "name": "peta-migrate",
  "type": "module",
  "version": "0.1.1",
  "description": "Migration tools for peta-orm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zfadhli/peta-stack.git"
  },
  "module": "src/index.ts",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "bin": {
    "peta": "./bin/peta"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "cac": "^7.0.0",
    "ora": "^9.4.0"
  },
  "peerDependencies": {
    "kysely": "^0.29.2",
    "peta-orm": "workspace:*",
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "@libsql/client": "^0.8.0",
    "@libsql/kysely-libsql": "^0.4.1",
    "@types/bun": "^1.3.14",
    "kysely": "^0.29.2",
    "peta-orm": "workspace:*",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "prepublish": "bun run build",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test"
  }
}
