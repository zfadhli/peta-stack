{
  "name": "peta-orm",
  "type": "module",
  "private": false,
  "version": "0.3.0",
  "description": "ORM for Bun, built on Kysely",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zfadhli/peta-stack.git"
  },
  "module": "src/index.ts",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./migrator": {
      "import": "./dist/migrations/index.mjs",
      "types": "./dist/migrations/index.d.mts"
    }
  },
  "bin": {
    "peta": "./bin/peta"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "arktype": "^2.2.0",
    "cac": "^7.0.0",
    "ora": "^9.4.0",
    "ulid": "^3.0.2"
  },
  "peerDependencies": {
    "kysely": "^0.28.17",
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "elysia": "^1.4.28",
    "hono": "^4.12.25",
    "kysely": "^0.28.17",
    "kysely-bun-sqlite": "^0.4.0",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.0"
  },
  "scripts": {
    "test": "bun test",
    "test:all": "for f in test/*.ts; do echo === $f ===; bun test $f || exit 1; done",
    "test:integration": "bun test test/integration/",
    "test:all:integration": "for f in test/integration/*.ts; do echo === $f ===; bun test $f || exit 1; done",
    "typecheck": "bun x tsc --noEmit",
    "build": "tsdown",
    "lint": "bunx biome check src test examples",
    "lint:fix": "bunx biome check --write --unsafe src test examples",
    "prepublish": "bun run build"
  }
}
