{
  "name": "peta-orm",
  "type": "module",
  "private": false,
  "version": "0.2.4",
  "description": "ORM for Bun, built on Kysely",
  "license": "MIT",
  "module": "src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./migrator": {
      "import": "./dist/migrations/index.js",
      "types": "./dist/migrations/index.d.ts"
    }
  },
  "bin": {
    "peta": "./bin/peta"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "arktype": "^2.2.0",
    "cac": "^7.0.0",
    "ora": "^9.4.0"
  },
  "peerDependencies": {
    "kysely": "^0.27.0",
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "kysely": "^0.27.0",
    "kysely-bun-sqlite": "^0.4.0",
    "typescript": "^6.0.0"
  },
  "scripts": {
    "test": "bun test",
    "test:all": "for f in test/*.ts; do echo === $f ===; bun test $f || exit 1; done",
    "typecheck": "bun x tsc --noEmit",
    "build:js": "bun build ./src/index.ts ./src/migrations/index.ts ./src/migrations/cli.ts --outdir ./dist --target bun --format esm --splitting",
    "build:types": "bun x tsc -p tsconfig.build.json",
    "build": "bun run build:js && bun run build:types",
    "lint": "bunx biome check src test examples",
    "lint:fix": "bunx biome check --write --unsafe src test examples",
    "prepublish": "bun run build"
  }
}
