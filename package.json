{
  "name": "peta-stack",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "docs"
  ],
  "scripts": {
    "test": "NODE_ENV=test bun test",
    "typecheck": "bun run --filter='*' typecheck",
    "build": "bun run --filter='*' build",
    "lint": "biome check packages/",
    "format": "biome check --write packages/",
    "docs:dev": "bun run --filter=docs dev",
    "docs:build": "bun run --filter=docs build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "ulid": "^3.0.2"
  }
}
